[Unit]
Description=Nexus Finance MCP Server
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/nexus-finance-mcp
ExecStart=/usr/bin/python3 server.py --transport streamable-http --port 8100
Restart=always
RestartSec=5
EnvironmentFile=/root/nexus-finance-mcp/.env

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nexus-finance-mcp

# Resource limits
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
