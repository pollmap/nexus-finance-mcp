# Nexus Finance MCP Server - Environment Variables
# Copy to .env and fill in your API keys

# === Korean Public Data APIs ===
BOK_ECOS_API_KEY=        # 한국은행 ECOS (https://ecos.bok.or.kr)
DART_API_KEY=            # OpenDART (https://opendart.fss.or.kr)
KOSIS_API_KEY=           # 통계청 KOSIS (https://kosis.kr)
RONE_API_KEY=            # 한국부동산원 (https://www.reb.or.kr)
KRX_API_KEY=             # 한국거래소

# === Korean Securities ===
KIS_API_KEY=             # 한국투자증권 KIS (https://apiportal.koreainvestment.com)
MOLIT_API_KEY=           # 국토교통부 실거래가

# === Korean Search/News ===
NAVER_CLIENT_ID=         # 네이버 검색 API (https://developers.naver.com)
NAVER_CLIENT_SECRET=     # 네이버 검색 API Secret

# === US/Global APIs ===
FRED_API_KEY=            # Federal Reserve FRED (https://fred.stlouisfed.org)
FINNHUB_API_KEY=         # Finnhub (https://finnhub.io)
EIA_API_KEY=             # US Energy Information Administration
EDINET_API_KEY=          # 일본 EDINET (https://disclosure.edinet-fsa.go.jp)

# === Crypto/Blockchain ===
ETHERSCAN_API_KEY=       # Etherscan (https://etherscan.io/apis)

# === Phase 7: Quant Alternative Data (optional) ===
NASA_API_KEY=            # NASA APIs (DONKI etc.) — DEMO_KEY works without registration
ENTSOE_API_KEY=          # ENTSO-E European Grid (email transparency@entsoe.eu)
ELECTRICITY_MAPS_TOKEN=  # Electricity Maps (https://app.electricitymaps.com)
ACLED_API_KEY=           # ACLED Conflict Data (https://acleddata.com)

# === Auth (optional) ===
MCP_AUTH_TOKEN=          # Bearer token for gateway authentication

# === Server Config ===
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8100
MCP_STATELESS=false
